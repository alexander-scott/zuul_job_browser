{
	"name": "zuulplugin",
	"displayName": "Zuul Job Browser",
	"publisher": "alexander-scott",
	"repository": "https://github.com/Alexander-Scott/zuulplugin",
	"description": "Navigate through Zuul Configuration in VSCode more easily with this plugin.",
	"version": "0.4.0",
	"license": "MIT",
	"engines": {
		"vscode": "^1.44.0",
		"npm": "11.17.0",
		"node": "26.5.0"
	},
	"packageManager": "npm@11.7.0",
	"categories": [
		"Programming Languages",
		"Other"
	],
	"activationEvents": [
		"onLanguage:yaml"
	],
	"icon": "images/zuul_icon.png",
	"main": "./out/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "zuul-job-browser",
					"title": "Zuul Job Browser",
					"icon": "images/zuul_icon.png"
				}
			]
		},
		"views": {
			"zuul-job-browser": [
				{
					"id": "zuulJobHierarchy",
					"name": "Job Hierarchy"
				},
				{
					"id": "zuulPlaybooks",
					"name": "Playbook Run Order"
				},
				{
					"id": "zuulVariables",
					"name": "Job Variables"
				}
			]
		},
		"commands": [
			{
				"command": "zuulplugin.rebuild-hierarchy",
				"title": "Zuul Plugin Rebuild Job Hierarchy"
			},
			{
				"command": "zuulplugin.clear-cache",
				"title": "Zuul Plugin Clear Job Hierarchy Cache"
			},
			{
				"command": "symbolOutline.revealRange",
				"title": "Reveal Range"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint src",
		"lint-fix": "eslint src --fix",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint && npm run copy-test-files",
		"copy-test-files": "rm -rf ./out/test/suite/test_files/ && cp -rv ./src/test/suite/test_files/ ./out/test/suite/test_files/",
		"test": "node ./out/test/runTest.js",
		"instrument": "nyc instrument out/ out/ --in-place",
		"coverage:report": "nyc report --reporter=text --reporter=lcov",
		"coverage:check": "nyc check-coverage --lines 100 --branches 100 --functions 100 --statements 100"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@types/glob": "^9.0.0",
		"@types/js-yaml": "^4.0.9",
		"@types/mocha": "^10.0.10",
		"@types/node": "^26.1.1",
		"@types/vscode": "^1.125.0",
		"@typescript-eslint/eslint-plugin": "^8.65.0",
		"@typescript-eslint/parser": "^8.64.0",
		"eslint": "^10.7.0",
		"glob": "^13.0.6",
		"nyc": "^18.0.0",
		"mocha": "^11.7.6",
		"typescript": "^6.0.3",
		"vscode-test": "^1.6.1"
	},
	"dependencies": {
		"class-transformer": "^0.5.1",
		"js-yaml": "^4.3.0",
		"lru-cache": "^11.5.2",
		"reflect-metadata": "^0.2.2",
		"vscode-cache": "^0.3.0"
	}
}
